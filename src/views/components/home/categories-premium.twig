{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| categories       | array   | Array of categories             |
#}

<section class="py-20 bg-black">
  <div class="max-width-7xl mx-auto px-5vw">
    {# Section Header #}
    <div class="text-center mb-16">
      <span class="text-xs uppercase tracking-widest text-gold font-latin block mb-3">Browse Our Selection</span>
      <h2 class="text-4xl lg:text-5xl font-bold text-cream mb-4 font-display">
        تسوّق حسب <em class="text-gold italic">التصنيف</em>
      </h2>
      <p class="text-smoke max-w-2xl mx-auto">
        من الضأن الإثيوبي إلى البقري الكيني — تشكيلة تلائم كل مناسبة ومائدة
      </p>
    </div>

    {# Categories Grid #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {% if categories %}
        {% for category in categories|slice(0, 5) %}
          <a href="{{ category.url }}" class="category-card {% if loop.first %}featured{% endif %}" title="{{ category.name }}">
            <div class="cat-bg" style="background: radial-gradient(circle at 50% 50%, rgba(155,28,28,0.2) 0%, rgba(8,8,7,1) 100%);"></div>
            <div class="cat-emoji">
              {% if loop.index == 1 %}🐄
              {% elseif loop.index == 2 %}🐑
              {% elseif loop.index == 3 %}🍗
              {% elseif loop.index == 4 %}🎁
              {% else %}⭐
              {% endif %}
            </div>
            <div class="cat-overlay"></div>
            <div class="cat-content">
              <span class="cat-label">
                {% if loop.index == 1 %}Beef
                {% elseif loop.index == 2 %}Lamb
                {% elseif loop.index == 3 %}Poultry
                {% elseif loop.index == 4 %}Bundles
                {% else %}Premium
                {% endif %}
              </span>
              <span class="cat-name">{{ category.name }}</span>
              <span class="cat-count">{{ category.products_count }} قطعة متوفرة</span>
            </div>
            <div class="cat-arrow">←</div>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
